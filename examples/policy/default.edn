;; A policy extends the built-in defaults (kernel primitives + the AI-generated /
;; untrusted lockdown). Here we bind the virtio-blk driver to its hardware
;; capabilities — crucially the IOMMU, without which its :dma effect is denied.
{:aiueos/policy :default

 ;; Extra kernel primitives this deployment exposes (unioned with the defaults).
 :aiueos/kernel-caps #{:ui/window}

 ;; Per-component grants. The driver is the only thing allowed to touch the IOMMU.
 :aiueos/grants
 {:driver/virtio-blk #{:iommu}}

 ;; Effects forbidden per trust level (overrides the default for that level).
 :aiueos/forbid
 {:ai-generated #{:network :secrets :persistent-write}
  :untrusted    #{:secrets}}}
