;; A sensor: reads hardware, publishes samples to the "scan" topic.
{:aiueos/component :driver/sensor
 :aiueos/kind :driver
 :aiueos/trust :untrusted
 :aiueos/wasm "sensor.wat"
 :aiueos/entry "tick"
 :aiueos/args [21]
 :aiueos/imports #{:topic/publish}
 :aiueos/exports #{:topic/scan}
 ;; name→id map: :aiueos/publishes is DERIVED from the exported topic (scan→1),
 ;; so the named graph topic and the runtime isolation id stay linked.
 :aiueos/topics {:scan 1}
 :aiueos/effects #{:device-io}
 :aiueos/limits {:memory-pages 4 :fuel 1000000}}
