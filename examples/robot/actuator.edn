;; An actuator: subscribes to "cmd" and drives the motor. It cannot publish —
;; it does not import :topic/publish, so a publish call would trap.
{:aiueos/component :driver/actuator
 :aiueos/kind :driver
 :aiueos/trust :untrusted
 :aiueos/wasm "actuator.wat"
 :aiueos/entry "tick"
 :aiueos/args [0]
 ;; subscribes to the "cmd" topic (consumes :topic/cmd). Because the planner is
 ;; the only provider of :topic/cmd, the broker boots the planner first.
 :aiueos/imports #{:topic/subscribe :topic/cmd}
 ;; subscribes (cmd→2) is DERIVED — the actuator reads only "cmd", not the sensor's topic.
 :aiueos/topics {:cmd 2}
 :aiueos/effects #{:device-io}
 :aiueos/limits {:memory-pages 4 :fuel 1000000}}
