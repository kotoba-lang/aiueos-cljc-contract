;; The filesystem service — exports fs/* and consumes block/* from a driver.
{:aiueos/component :service/fs
 :aiueos/kind :service
 :aiueos/trust :verified
 :aiueos/source "fs-service.clj"
 :aiueos/entry "init"
 :aiueos/args []
 :aiueos/imports #{:block/read :block/write}
 :aiueos/exports #{:fs/open :fs/read :fs/write :fs/list}
 :aiueos/effects #{:storage}
 :aiueos/limits {:memory-pages 32 :fuel 5000000}}
