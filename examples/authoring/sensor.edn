;; Matching manifest. :aiueos/publishes is DERIVED from the :topic/scan export via
;; the topics map (→ #{1}); imports grant the host capabilities the WAT calls.
{:aiueos/component :driver/sensor
 :aiueos/kind :driver
 :aiueos/wasm "sensor.wat"
 :aiueos/entry "tick"
 :aiueos/imports #{:topic/publish :random/bytes}
 :aiueos/exports #{:topic/scan}
 :aiueos/topics {:scan 1}}
