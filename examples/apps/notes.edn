;; A user app. Imports only capabilities a notes app should have: a file the user
;; chose, plus logging. No network, no secrets, no ambient filesystem.
{:aiueos/component :app/notes
 :aiueos/kind :app
 :aiueos/trust :untrusted
 :aiueos/source "notes.clj"
 :aiueos/entry "main"
 :aiueos/args [21]
 :aiueos/imports #{:fs/open :log/write}
 :aiueos/exports #{:app/main}
 :aiueos/effects #{:read-file :write-file}
 :aiueos/limits {:memory-pages 64 :fuel 5000000}}
